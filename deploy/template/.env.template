# Organization identity
ORG_NAME=${ORG_NAME}
TRAEFIK_HOST=${TRAEFIK_HOST}

# Runtime
NODE_ENV=production
PORT=3000
LOG_LEVEL=info
ENFORCE_HTTPS=true

# Application URLs
API_BASE_URL=https://${TRAEFIK_HOST}
VITE_API_URL=https://${TRAEFIK_HOST}
CORS_ORIGIN=https://${TRAEFIK_HOST}

# Database and cache
DATABASE_PASSWORD=${DATABASE_PASSWORD}
DATABASE_URL=postgresql://aether:${DATABASE_PASSWORD}@postgres:5432/aether_${ORG_NAME}
REDIS_URL=redis://redis:6379

# Authentication secrets (replace with generated values during provisioning)
JWT_ACCESS_SECRET=${JWT_ACCESS_SECRET}
JWT_REFRESH_SECRET=${JWT_REFRESH_SECRET}

# Rate limits
RATE_LIMIT_GLOBAL=200
RATE_LIMIT_AUTH=10

# SMTP (optional, required for email receipts/notifications)
SMTP_HOST=${SMTP_HOST}
SMTP_PORT=${SMTP_PORT:-587}
SMTP_USER=${SMTP_USER}
SMTP_PASS=${SMTP_PASS}
SMTP_FROM=${SMTP_FROM}

# Optional TLS paths inside backend container
TLS_KEY_PATH=/etc/aether/tls/tls.key
TLS_CERT_PATH=/etc/aether/tls/tls.crt
TLS_CA_PATH=/etc/aether/tls/ca.crt
