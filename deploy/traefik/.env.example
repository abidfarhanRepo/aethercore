# Public domain for tenant traffic (showcase domain)
TRAEFIK_HOST=alfazam.com

# Dashboard host should be a separate subdomain
DASHBOARD_HOST=traefik.alfazam.com

# Let's Encrypt registration email
ACME_EMAIL=ops@alfazam.com

# Basic auth users for Traefik dashboard. Generate with:
#   htpasswd -nb admin "replace-with-strong-password"
# Then escape $ as $$ in this file.
TRAEFIK_DASHBOARD_USERS=admin:$$apr1$$replace_me$$replace_me
